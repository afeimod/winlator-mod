<?xml version="1.0" encoding="utf-8"?>
<resources>
    <attr name="value" format="float" />
    <attr name="minValue" format="integer|float" />
    <attr name="maxValue" format="integer|float" />
    <attr name="step" format="integer|float" />
    <attr name="textSize" format="dimension" />
    <declare-styleable name="NumberPicker">
        <attr name="value" />
        <attr name="minValue" />
        <attr name="maxValue" />
        <attr name="step" />
        <attr name="textSize" />
    </declare-styleable>
    <declare-styleable name="SeekBar">
        <attr name="value" />
        <attr name="minValue" />
        <attr name="maxValue" />
        <attr name="step" />
        <attr name="suffix" format="string" />
        <attr name="textSize" />
    </declare-styleable>
</resources>